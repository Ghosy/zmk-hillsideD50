// User default keymap.
// It is recommended to not edit this in boards/shields/hillside_d50/,
// but rather to copy into config/ and edit there.
// Can only use one of backlight or RGB

#include <behaviors.dtsi>
#include <dt-bindings/zmk/backlight.h>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/outputs.h>

//#include <dt-bindings/zmk/rgb.h>

#define BASE_L   0
#define NAV_L    1
#define SYM_L    2
#define ADJ_L    3
#define Undo   LC(Z)
#define Cut    LC(X)
#define Copy   LC(C)
#define Paste  LC(V)
#define Redo   LC(Y)

/ {
    keymap {
        compatible = "zmk,keymap";

        // // Build test layer, if using the bare LED.
        // // Need to also ensure normal layers don't use smart LED key codes, such as by commenting them all out.
        // // col 0         1               2                3                4              5
        //         test_layer { bindings = <
        // &kp  TAB        &kp  Q          &kp  W           &kp  E           &kp  R         &kp  T                   &kp  Y        &kp  U         &kp  I            &kp  O           &kp  P           &kp  LBKT
        // &bl  BL_TOG     &bl  BL_CYCLE   &kp  S           &ext_power EP_ON &out OUT_USB   &out OUT                 &out OUT_BLE  &out OUT_USB   &ext_power EP_ON  &kp  L           &bl  BL_CYCLE    &bl  BL_TOG
        // &kp  N0         &kp  N1         &kp  N2          &kp  N3          &kp  N4        &kp  N5                  &kp  N5       &kp  N4        &kp  N3           &kp  N2          &kp  N1          &kp  N0
        //                                 &kp  X           &kp  C             &kp  N1        &kp  N2              &kp  N2       &kp  N1          &kp  COMMA        &kp  DOT
        //                                                    &kp  N5          &kp  N4        &kp  N3              &kp  N3       &kp  N4        &kp  N5
        //                          >; };
        // // Build test layer, if using the smart RGB LEDs.
        // // Need to also ensure normal layers don't use bare LED key codes, such as by commenting them all out.
        // // col 0         1               2               3                4              5
        //         test_layer { bindings = <
        // &kp  TAB        &kp  Q          &kp  W          &kp  E           &kp  R         &kp  T                   &kp  Y        &kp  U         &kp  I            &kp  O           &kp  P           &kp  LBKT
        // &rgb_ug RGB_ON  &rgb_ug RGB_BRI &rgb_ug RGB_OFF &ext_power EP_ON &out OUT_USB   &out OUT                 &out OUT_BLE  &out OUT_USB   &ext_power EP_ON  &rgb_ug RGB_OFF  &rgb_ug RGB_BRI  &rgb_ug RGB_ON
        // &kp  N0         &kp  N1         &kp  N2         &kp  N3          &kp  N4        &kp  N5                  &kp  N5       &kp  N4        &kp  N3           &kp  N2          &kp  N1          &kp  N0
        //                                 &kp  X          &kp  C              &kp  N1       &kp  N2              &kp  N2       &kp  N1          &kp  COMMA        &kp  DOT
        //                                                   &kp  N5           &kp  N4       &kp  N3              &kp  N3       &kp  N4        &kp  N5
        //                          >; };

        default_layer {
            display-name = "Base";
            bindings = <
&kp TAB        &kp APOSTROPHE  &kp COMMA      &kp PERIOD    &kp P         &kp Y      &kp F   &kp G     &kp C  &kp O  &kp L  &kp SLASH
&kp ESC        &kp A           &kp O          &kp E         &kp U         &kp I      &kp D   &kp H     &kp T  &kp N  &kp S  &kp MINUS
&kp LSHFT      &kp SEMICOLON   &kp Q          &kp J         &kp K         &kp X      &kp B   &kp M     &kp W  &kp V  &kp Z  &kp RSHFT
&kp LEFT       &kp RIGHT       &mo 1          &kp LEFT_ALT  &kp LEFT_ALT  &kp LCTRL  &kp UP  &kp DOWN
&kp BACKSPACE  &sk LSHIFT      &kp LEFT_META  &mo 2         &mo 1         &kp SPACE
            >;
        };

        sym_layer {
            display-name = "Sym";
            bindings = <
&trans  &kp LEFT_BRACKET  &kp LEFT_BRACE        &kp RIGHT_BRACE        &kp RIGHT_BRACKET  &none  &none  &none        &none          &none     &none      &none
&trans  &kp BSLH          &kp LEFT_PARENTHESIS  &kp RIGHT_PARENTHESIS  &kp BACKSLASH      &none  &none  &kp LEFT     &kp QUESTION   &kp PLUS  &kp EQUAL  &none
&trans  &none             &none                 &kp DOWN               &kp UP             &none  &none  &kp PAGE_UP  &kp PAGE_DOWN  &none     &none      &none
&none   &none             &key_repeat           &none                  &none              &mo 3  &none  &none
&none   &none             &mo 3                 &trans                 &none              &none
            >;
        };

        nav_layer {
            display-name = "Nav";
            bindings = <
&kp Copy  &kp N1    &kp N2    &kp N3     &kp N4     &kp N5     &kp N6     &kp N7     &kp N8  &kp N9    &kp N0     &trans
&kp Cut   &kp LGUI  &kp LALT  &kp LCTRL  &kp LSHFT  &kp Paste  &kp HOME   &kp LEFT   &kp UP  &kp DOWN  &kp RIGHT  &kp END
&trans    &kp F1    &kp F2    &kp F3     &kp F4     &kp F5     &kp F6     &kp F7     &kp F8  &kp F9    &kp F10    &trans
&kp Undo  &kp Redo  &mo 3     &none      &none      &kp DOT    &kp PG_UP  &kp PG_DN
&none     &none     &trans    &mo 3      &trans     &kp COMMA
            >;
        };

        adj_layer {
            display-name = "Adjust";
            bindings = <
&none        &none         &out OUT_BLE  &out OUT_USB  &none         &soft_off     &soft_off  &none     &none            &none         &none       &none
&none        &bt BT_SEL 0  &bt BT_SEL 1  &bt BT_SEL 2  &bt BT_SEL 3  &bt BT_SEL 4  &none      &none     &out OUT_USB     &out OUT_BLE  &none       &none
&bootloader  &sys_reset    &none         &none         &none         &none         &kp PSCRN  &kp SLCK  &kp PAUSE_BREAK  &none         &sys_reset  &bootloader
&bl BL_TOG   &bl BL_CYCLE  &none         &none         &none         &none         &none      &none
&bt BT_CLR   &none         &trans        &trans        &none         &none
            >;
        };
    };
};
